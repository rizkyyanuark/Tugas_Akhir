@InProceedings{10.1007/978-3-030-62466-8_19,
author="Michel, Franck
and Gandon, Fabien
and Ah-Kane, Valentin
and Bobasheva, Anna
and Cabrio, Elena
and Corby, Olivier
and Gazzotti, Rapha{\"e}l
