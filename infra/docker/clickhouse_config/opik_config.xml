<clickhouse>
    <macros>
        <shard>1</shard>
        <replica>clickhouse</replica>
        <cluster>default</cluster>
    </macros>

    <zookeeper>
        <node>
            <host>opik-zookeeper</host>
            <port>2181</port>
        </node>
    </zookeeper>

    <remote_servers>
        <default>
            <shard>
                <weight>1</weight>
                <internal_replication>true</internal_replication>
                <replica>
                    <host>opik-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </default>
    </remote_servers>
</clickhouse>
