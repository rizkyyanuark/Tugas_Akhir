# 1. Supabase Database Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key

# 2. SciVal / Scopus Scraping Credentials
SCIVAL_EMAIL=your_email@domain.com
SCIVAL_PASS=your_password

# 3. SerpAPI (Google Scholar) Configuration
SERPAPI_KEY=your_serpapi_key_here

# 4. BrightData / Proxy (Opsional)
BD_PASS_SERP=your_brightdata_password

# ==============================================================================
# Legacy / Standalone Configurations (Neo4j, Grafana, etc)
# ==============================================================================
NEO4J_AUTH=neo4j/your_neo4j_password
NEO4J_PASSWORD=your_neo4j_password
GRAFANA_ADMIN_PASSWORD=your_grafana_password
