# ==============================================================================
# 🚀 UNESA PAPERS ETL - ENVIRONMENT TEMPLATE
# ==============================================================================
# Copy this file to .env and fill in your actual credentials.
# DO NOT COMMIT THE .ENV FILE TO VERSION CONTROL.
# ==============================================================================

# 1. Supabase Database Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# 2. SciVal / Scopus Scraping Credentials
SCIVAL_EMAIL=your_email@example.com
SCIVAL_PASS=your_password

# 3. SerpAPI (Google Scholar) Configuration
SERPAPI_KEY=your_serpapi_key

# 4. BrightData / Proxy (Opsional)
BD_PASS_SERP=your_brightdata_pass
BD_USER_SERP=your_brightdata_user
BD_PASS_UNLOCKER=your_brightdata_unlocker_pass
BD_USER_UNLOCKER=your_brightdata_unlocker_user

# ==============================================================================
# Infrastructure & Monitoring Credentials
# ==============================================================================
PASSWORD=your_secure_password
NEO4J_AUTH=neo4j/your_secure_password
NEO4J_PASSWORD=your_secure_password
GRAFANA_ADMIN_PASSWORD=your_secure_password
AIRFLOW_ADMIN_PASSWORD=your_secure_password
POSTGRES_PASSWORD=your_secure_password

# 5. AI / LLM API Keys
HF_TOKEN=your_huggingface_token
OPENROUTER_API_KEY=your_openrouter_key
GROQ_API_KEY=your_groq_key

# 6. Remote Connections (Amazon EC2)
NEO4J_URI=bolt://your_ec2_ip:7687
WEAVIATE_HOST=your_ec2_ip
WEAVIATE_PORT=8081

# 7. Opik LLM Monitoring (Self-Hosted)
OPIK_URL=http://your_ec2_ip:5173
OPIK_WORKSPACE=default

# 8. Airflow Security
AIRFLOW_FERNET_KEY=your_fernet_key_here

# 9. AWS Deployment (for CI/CD Pipeline)
AWS_ACCOUNT_ID=your_aws_account_id
AWS_REGION=us-east-1
EC2_IP=your_ec2_public_ip
