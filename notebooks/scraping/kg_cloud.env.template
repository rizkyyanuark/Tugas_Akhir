# KG cloud notebook environment template (Kaggle/Colab)
# Copy these keys into notebook secrets or environment variables.

# Required: Supabase source
SUPABASE_URL=https://your-project-ref.supabase.co
# Use service role key for full table access in offline pipeline jobs.
SUPABASE_KEY=your_supabase_service_role_key

# Required: Hosted Neo4j sink
# For Neo4j Aura use neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=neo4j+s://your-hosted-neo4j-uri
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
# Optional. Defaults to neo4j if not set.
NEO4J_DATABASE=neo4j

# Required: LLM curation
GROQ_API_KEY=your_groq_api_key

# Optional runtime controls
KG_TEST_MODE=true
KG_CLEAR_DB=true
KG_MAX_PAPERS=5000
KG_LLM_BATCH_SIZE=80

# Set false when running cloud notebook without a Milvus service.
KG_ENABLE_MILVUS=false

# Optional path override for notebook setup cell root detection.
# Example Kaggle: /kaggle/working/Tugas_Akhir
# Example Colab: /content/Tugas_Akhir
KG_PROJECT_ROOT=
